:80 {
	root * /assets/dist
	file_server

	# SPA fallback
	try_files {path} /index.html

	# Security headers
	header {
		X-Frame-Options "DENY"
		X-Content-Type-Options "nosniff"
		Strict-Transport-Security "max-age=31536000; includeSubDomains"
		Content-Security-Policy "default-src 'self'; connect-src https://api.vanguardkyc.online https://api.ipify.org http://localhost:*; img-src 'self' https://api.vanguardkyc.online blob: data:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline'; frame-ancestors 'none'; base-uri 'self'; form-action 'self'"
		Permissions-Policy "camera=(), microphone=(), geolocation=(), payment=()"
		Referrer-Policy "strict-origin-when-cross-origin"
		-Server
	}
}
